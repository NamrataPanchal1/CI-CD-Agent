# Copy this file to `.env` and adjust values as needed for local development.
# Never commit a real `.env` file.

# --- Application identity ---------------------------------------------------
APP_NAME=AI-CI-CD-Agent
APP_VERSION=0.1.0
# One of: development | staging | production | test
APP_ENV=development

# --- API server --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging -------------------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# One of: json | text  (use "text" for easier local reading, "json" for prod/CloudWatch)
LOG_FORMAT=json

# --- GitHub (Phase 2) ---------------------------------------------------------
# Personal Access Token with at least `repo` (or `public_repo` for public-only)
# scope. Required for any /repos/* endpoint to work.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REQUEST_TIMEOUT_SECONDS=10.0

# --- Future phases will add: -------------------------------------------------
# GITHUB_WEBHOOK_SECRET=
# AWS_REGION=
# AWS_ACCOUNT_ID=
# BEDROCK_MODEL_ID=
# ECR_REPOSITORY_URI=
# SES_SENDER_EMAIL=
